  "item": [
    {
      "name": "yandex get orders",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const login    = pm.environment.get(\"YT_LOGIN\");\r",
              "const password = pm.environment.get(\"YT_PASSWORD\");\r",
              "\r",
              "// 1) Generate UNIX timestamp (seconds)\r",
              "const timestamp = Math.floor(Date.now()/1000).toString();\r",
              "\r",
              "// 2) MD5(password)\r",
              "const md5 = CryptoJS.MD5(password).toString();\r",
              "\r",
              "// 3) SHA1(md5 + timestamp)\r",
              "const sha1 = CryptoJS.SHA1(md5 + timestamp).toString();\r",
              "\r",
              "// 4) Build auth token and set as env var\r",
              "const auth = `${login}:${sha1}:${timestamp}`;\r",
              "pm.environment.set(\"YT_AUTH\", auth);\r",
              "\r",
              "//— optional: log to console for debugging\r",
              "console.log(\"Yandex auth:\", auth);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "https://api.tickets.yandex.net/api/crm/?action=crm.order.list&auth={{YT_AUTH}}&city_id={{YT_CITY_ID}}&start_date=2025-07-14T01:56:08+0300&end_date=2025-07-16T01:56:08+0300",
          "protocol": "https",
          "host": [
            "api",
